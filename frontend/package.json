{
  "name": "curion-landing-page",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:extension": "tsc -p tsconfig.node.json",
    "package:extension": "npm run build:extension && npm exec -- tsc -p ../extension/tsconfig.json && node ./.cache/build-extension.js",
    "predev": "npm run package:extension",
    "dev": "vite",
    "prebuild": "npm run package:extension",
    "build": "npm run typecheck && vite build",
    "prepreview": "npm run package:extension",
    "preview": "vite preview --host 127.0.0.1 --port 5173"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
