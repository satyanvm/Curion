{
  "name": "curion-landing-page",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "package:extension": "npm run build:ts && npm exec -- tsc -p ../extension/tsconfig.json && node ./dist/build-extension.js",
    "predev": "npm run package:extension",
    "dev": "python3 -m http.server 5173",
    "prebuild": "npm run package:extension",
    "build": "npm run build:ts && node --check dist/script.js",
    "prepreview": "npm run package:extension",
    "preview": "python3 -m http.server 5173"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
